# ~/.config/claude/statusline.env
# Per-machine statusline tweaks. Sourced by statusline.sh.
# Values default to 1 (show); set to 0 to hide.

# What to show on line 1 (identity)
SHOW_HOST=1        # short hostname
SHOW_DIR=1         # cwd (basename if in repo, ~/short/path otherwise)
SHOW_GIT=1         # branch + dirty status
SHOW_ENV=1         # active uv/conda env
SHOW_GPU=1         # nvidia-smi summary (auto-skipped if no GPUs)
SHOW_SLURM=1       # squeue -u $USER count (auto-skipped if no slurm)

# What to show on line 2 (session)
SHOW_MODEL=1       # claude model name
SHOW_CTX=1         # context bar + percent
SHOW_COST=1        # session cost + $/hour burn rate
SHOW_TOKENS=1      # total tokens + tokens/min
SHOW_RATE=1        # 5h rate limit bar + reset countdown

# Cache TTL in seconds for expensive probes (gpu, slurm)
CACHE_TTL=5

# Hostname color override (regex-based, optional). Format: PATTERN:COLOR
# Colors: 30-37 (normal) or 90-97 (bright). Examples below.
# HOST_COLORS=("bair-:36" "fair-:35" "h100-:33")
HOST_COLORS=()
